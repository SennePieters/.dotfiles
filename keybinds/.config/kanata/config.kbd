;; This tells Kanata we want to intercept the physical Caps Lock key
(defsrc
  caps)

;; Define our dual-role behavior
;; 200ms tap threshold, 200ms hold threshold
;; Tap = caps, Hold = left meta (Super/Windows)
(defalias
  cap (tap-hold 200 200 caps lmet))

;; Apply our alias to the base layer
(deflayer base
  @cap)